# Django Configuration
DJANGO_SECRET_KEY=your-unique-secret-key-generate-with-python-secrets
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app-name.onrender.com

# Database (Neon Postgres recommended)
# Get from https://neon.tech/dashboard
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=tena_wellness_bot

# Frontend Configuration
MINI_APP_URL=https://tena-app.netlify.app
FRONTEND_ORIGIN=https://tena-app.netlify.app

# AI Configuration
GEMINI_API_KEY=your-gemini-api-key-from-ai.google.dev

# Development/Production
ALLOW_DEV_AUTH=false

# Optional: Google Speech-to-Text
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
