# Django
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Neon Postgres (paste the pooled connection string from Neon dashboard)
# Example: postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Public HTTPS URL where the Mini App is hosted (e.g. https://yourapp.vercel.app)
MINI_APP_URL=http://localhost:5173

# Gemini
GEMINI_API_KEY=

# Google Speech-to-Text (path to service account JSON). Optional - we fall back to Gemini for audio.
GOOGLE_APPLICATION_CREDENTIALS=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
